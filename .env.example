# ── LLM API Keys ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Agent Arena ──────────────────────────────────────────────────────────────
AGENTARENA_API_KEY=your-agent-arena-api-key
WEBHOOK_AUTH_TOKEN=your-secret-webhook-token

# ── Optional ─────────────────────────────────────────────────────────────────
# Global model override — forces ALL tasks to use this model (overrides tier selection)
# AVADHI_MODEL=gpt-4o

# Per-tier model selection (only used when AVADHI_MODEL is NOT set)
# AVADHI_DEFAULT_MODEL=gpt-4o            # Low-bounty / test tasks
# AVADHI_PREMIUM_MODEL=claude-opus-4-5   # High-bounty tasks (Opus quality)
# AVADHI_FALLBACK_MODEL=gpt-4o           # Auto-fallback when Claude hits rate limits

# Bounty threshold in USD above which the premium model is used
# AVADHI_BOUNTY_THRESHOLD=5000

# Per-provider rate limits (tune to your API tier)
# AVADHI_ANTHROPIC_RPM=50
# AVADHI_ANTHROPIC_ITPM=30000
# AVADHI_ANTHROPIC_OTPM=8000
# AVADHI_OPENAI_RPM=500
# AVADHI_OPENAI_ITPM=500000

# RAG database (optional)
# DATABASE_URL=postgresql://user:pass@localhost:5432/avadhi
# VOYAGE_API_KEY=...
